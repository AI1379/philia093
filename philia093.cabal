cabal-version:      3.0
-- The cabal-version field refers to the version of the .cabal specification,
-- and can be different from the cabal-install (the tool) version and the
-- Cabal (the library) version you are using. As such, the Cabal (the library)
-- version used must be equal or greater than the version stated in this field.
-- Starting from the specification version 2.2, the cabal-version field must be
-- the first thing in the cabal file.

-- Initial package description 'philia093' generated by
-- 'cabal init'. For further documentation, see:
--   http://haskell.org/cabal/users-guide/
--
-- The name of the package.
name:               philia093

-- The package version.
-- See the Haskell package versioning policy (PVP) for standards
-- guiding when and how versions should be incremented.
-- https://pvp.haskell.org
-- PVP summary:     +-+------- breaking API changes
--                  | | +----- non-breaking API additions
--                  | | | +--- code changes with no API change
version:            0.1.0.0

-- A short (one-line) description of the package.
-- synopsis:

-- A longer description of the package.
-- description:

-- The license under which the package is released.
license:            MIT

-- The file containing the license text.
license-file:       LICENSE

-- The package author(s).
author:             Renatus Madrigal

-- An email address to which users can send suggestions, bug reports, and patches.
maintainer:         listener1381@outlook.com

-- A copyright notice.
-- copyright:
build-type:         Simple

-- Extra doc files to be distributed with the package, such as a CHANGELOG or a README.
extra-doc-files:    README.md

-- Extra source files to be distributed with the package, such as examples, or a tutorial module.
-- extra-source-files:

common warnings
    ghc-options: -Wall

common extensions
    default-extensions:
        OverloadedStrings
        DeriveGeneric
        RecordWildCards
        FlexibleContexts
        GeneralizedNewtypeDeriving
        FlexibleInstances
        MultiParamTypeClasses
        DerivingStrategies
        StandaloneDeriving
        UndecidableInstances
        DuplicateRecordFields
        OverloadedRecordDot
        LambdaCase
        ImportQualifiedPost
    default-language: GHC2021

library
    import:           warnings, extensions
    exposed-modules:
        Philia093.Types
        Philia093.Email
        Philia093.Processor
        Philia093.Notify
        Philia093.App
        Philia093.Utilities
        Philia093.InfoSource

        Philia093.LLM.LLMProvider
        Philia093.LLM.LLMTypes
        Philia093.LLM.OpenAI

        Philia093.Email.EmailTypes
        Philia093.Email.IMAPService
        Philia093.Email.SMTPService

        Philia093.InfoSource.Arxiv
    
    other-modules:
        Philia093.Email.Utilities

    build-depends:
        base ^>=4.18.3.0,
        text,
        bytestring,
        aeson,
        yaml,
        containers,
        http-conduit,
        http-types,
        mime-mail,
        smtp-mail,
        HaskellNet,
        HaskellNet-SSL,
        mtl,
        transformers,
        directory,
        filepath,
        time,
        base64-bytestring,
        async,
        network,
        purebred-email,
        lens,
        case-insensitive
    hs-source-dirs:   src

executable philia093
    -- Import common warning flags.
    import:           warnings, extensions

    -- .hs or .lhs file containing the Main module.
    main-is:          Main.hs

    -- Modules included in this executable, other than Main.
    -- other-modules:

    -- LANGUAGE extensions used by modules in this package.
    -- other-extensions:

    -- Other library packages from which modules are imported.
    build-depends:
        base ^>=4.18.3.0,
        text,
        yaml,
        mtl,
        philia093

    -- Directories containing source files.
    hs-source-dirs:   app

test-suite philia093-tests
    import:           warnings, extensions
    type:             exitcode-stdio-1.0
    main-is:          Spec.hs
    hs-source-dirs:   tests

    -- Modules included in this test suite to make HLS happy.
    other-modules:
        ArxivParserSpec
    build-depends:
        base ^>=4.18.3.0,
        hspec,
        text,
        time,
        containers,
        raw-strings-qq,
        neat-interpolation,
        philia093
